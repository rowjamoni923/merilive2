<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface">
        <ImageButton android:id="@+id/btnBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_back" android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Agent Wallet"
            android:textSize="18sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:gravity="center" />
        <View android:layout_width="40dp" android:layout_height="40dp" />
    </LinearLayout>

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:layout_marginTop="32dp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Total Beans -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="16dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Beans" android:textColor="@color/text_secondary" android:textSize="14sp" />
                    <TextView android:id="@+id/tvTotalBeans"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="36sp" android:textStyle="bold" android:textColor="@color/accent"
                        android:text="0" android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Diamonds & Commission Row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                    android:padding="16dp" android:background="@drawable/bg_card">
                    <TextView android:id="@+id/tvDiamonds"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/primary" android:text="0" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💎 Diamonds" android:textColor="@color/text_secondary" />
                </LinearLayout>
                <View android:layout_width="8dp" android:layout_height="0dp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                    android:padding="16dp" android:background="@drawable/bg_card">
                    <TextView android:id="@+id/tvCommissionRate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="22sp" android:textStyle="bold" android:textColor="@color/primary" android:text="0%" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Commission" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons -->
            <Button android:id="@+id/btnWithdraw"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_primary_button"
                android:text="💰 Withdraw" android:textColor="@android:color/white"
                android:textStyle="bold" android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btnTransferHistory"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_card"
                android:text="📋 Transfer History" android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btnCommissionHistory"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@drawable/bg_card"
                android:text="💵 Commission History" android:textColor="@color/text_primary" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
