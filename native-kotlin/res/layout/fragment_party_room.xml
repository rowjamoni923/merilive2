<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/party_bg">
    <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_back" android:background="@drawable/bg_circle_translucent" android:layout_gravity="top|start" android:layout_margin="16dp" />
    <TextView android:id="@+id/tvRoomName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:layout_marginTop="20dp" />
    <TextView android:id="@+id/tvViewerCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/accent" android:layout_gravity="top|end" android:layout_margin="20dp" />
    <!-- 9-seat grid would be a custom GridLayout here -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_gravity="bottom" android:padding="16dp" android:gravity="center">
        <ImageButton android:id="@+id/btnMic" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_mic" android:background="@drawable/bg_circle_translucent" />
        <ImageButton android:id="@+id/btnGift" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_gift" android:background="@drawable/bg_circle_translucent" android:layout_marginStart="20dp" />
    </LinearLayout>
    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone" />
</FrameLayout>