<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="#0A0A0F" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="⚙️ Room Settings" android:textColor="#FFFFFF" android:textSize="18sp"
        android:textStyle="bold" android:layout_marginBottom="20dp" />
    <!-- Free Seats Toggle -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Free Seat Mode" android:textColor="#FFFFFF" android:textSize="15sp" />
        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchFreeSeats"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>
    <!-- Lock All Seats -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Lock All Seats" android:textColor="#FFFFFF" android:textSize="15sp" />
        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchLockAll"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>
    <!-- Clear Seats -->
    <com.google.android.material.button.MaterialButton android:id="@+id/btnClearAllSeats"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginBottom="12dp" android:text="Clear All Seats"
        android:textAllCaps="false" android:backgroundTint="#F59E0B" />
    <!-- End Party -->
    <com.google.android.material.button.MaterialButton android:id="@+id/btnEndParty"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:text="End Party" android:textAllCaps="false" android:backgroundTint="#DC2626" />
</LinearLayout>
