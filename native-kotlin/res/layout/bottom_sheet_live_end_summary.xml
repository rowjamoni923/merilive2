<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="#0A0A0F" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎉 Stream Ended" android:textColor="#FFFFFF" android:textSize="22sp"
        android:textStyle="bold" android:layout_gravity="center" android:layout_marginBottom="20dp" />
    <!-- Stats Grid -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="12dp"
            android:background="#1A1A2E">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⏱ Duration" android:textColor="#9CA3AF" android:textSize="11sp" />
            <TextView android:id="@+id/tvDuration" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="12dp"
            android:background="#1A1A2E" android:layout_marginStart="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👁 Viewers" android:textColor="#9CA3AF" android:textSize="11sp" />
            <TextView android:id="@+id/tvTotalViewers" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="12dp"
            android:background="#1A1A2E">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🎁 Gifts" android:textColor="#9CA3AF" android:textSize="11sp" />
            <TextView android:id="@+id/tvTotalGifts" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFD700" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="12dp"
            android:background="#1A1A2E" android:layout_marginStart="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🫘 Beans" android:textColor="#9CA3AF" android:textSize="11sp" />
            <TextView android:id="@+id/tvTotalBeans" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#10B981" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:padding="12dp"
            android:background="#1A1A2E">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="➕ New Followers" android:textColor="#9CA3AF" android:textSize="11sp" />
            <TextView android:id="@+id/tvNewFollowers" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#7C3AED" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
    <com.google.android.material.button.MaterialButton android:id="@+id/btnClose"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Close" android:textAllCaps="false" android:backgroundTint="#7C3AED" />
</LinearLayout>
