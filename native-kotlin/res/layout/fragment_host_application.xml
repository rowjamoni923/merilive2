<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="?selectableItemBackgroundBorderless" android:src="@drawable/ic_back" android:tint="@color/text_primary" android:contentDescription="Back" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true" android:text="Host Application" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
    </RelativeLayout>

    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_marginTop="50dp" android:visibility="gone" />

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

            <!-- Existing Application Status -->
            <LinearLayout android:id="@+id/layoutExistingStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card" android:padding="16dp" android:orientation="vertical" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Application Status" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvApplicationStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/accent_gold" android:textSize="14sp" android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Search Form -->
            <LinearLayout android:id="@+id/layoutSearchForm" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Enter App UID" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <EditText android:id="@+id/etAppUid" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:background="@drawable/bg_input_field" android:hint="LV1234567890" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:paddingHorizontal="12dp" android:inputType="text" android:textSize="14sp" />
                    <Button android:id="@+id/btnSearchUser" android:layout_width="80dp" android:layout_height="48dp" android:layout_marginStart="8dp" android:background="@drawable/bg_primary_button" android:text="Search" android:textColor="@color/white" android:textSize="13sp" />
                </LinearLayout>

                <!-- User Not Found -->
                <TextView android:id="@+id/tvUserNotFound" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="User not found" android:textColor="#FF5555" android:textSize="13sp" android:layout_marginTop="8dp" android:visibility="gone" />

                <!-- Found User Card -->
                <LinearLayout android:id="@+id/layoutUserFound" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card" android:padding="12dp" android:layout_marginTop="12dp" android:orientation="horizontal" android:gravity="center_vertical" android:visibility="gone">
                    <ImageView android:id="@+id/ivFoundAvatar" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_avatar_placeholder" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:id="@+id/tvFoundUserName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvFoundUserUid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_secondary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- App Verification -->
                <LinearLayout android:id="@+id/layoutAppVerification" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step 1: App Verification" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    <Button android:id="@+id/btnSendAppCode" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="8dp" android:background="@drawable/bg_card" android:text="Send Code to App" android:textColor="@color/text_primary" android:textSize="13sp" />
                    <EditText android:id="@+id/etAppCode" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input_field" android:hint="Enter 6-digit code" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:paddingHorizontal="12dp" android:inputType="number" android:textSize="14sp" />
                    <Button android:id="@+id/btnVerifyAppCode" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="8dp" android:background="@drawable/bg_primary_button" android:text="Verify" android:textColor="@color/white" android:textSize="13sp" />
                </LinearLayout>

                <!-- Email Verification -->
                <LinearLayout android:id="@+id/layoutEmailVerification" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp" android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step 2: Email Verification" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input_field" android:hint="Email address" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:paddingHorizontal="12dp" android:inputType="textEmailAddress" android:textSize="14sp" />
                    <Button android:id="@+id/btnSendEmailCode" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="8dp" android:background="@drawable/bg_card" android:text="Send Email Code" android:textColor="@color/text_primary" android:textSize="13sp" />
                    <EditText android:id="@+id/etEmailCode" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input_field" android:hint="Enter email code" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:paddingHorizontal="12dp" android:inputType="number" android:textSize="14sp" />
                    <Button android:id="@+id/btnVerifyEmailCode" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="8dp" android:background="@drawable/bg_primary_button" android:text="Verify" android:textColor="@color/white" android:textSize="13sp" />
                </LinearLayout>

                <!-- Submit -->
                <LinearLayout android:id="@+id/layoutSubmit" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp" android:visibility="gone">
                    <Button android:id="@+id/btnSubmit" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_primary_button" android:text="Submit Application" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
