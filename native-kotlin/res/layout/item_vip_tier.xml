<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="140dp" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="center"
    android:padding="12dp" android:layout_marginEnd="8dp"
    android:background="@drawable/bg_card">
    <TextView android:id="@+id/tvTierName" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="16sp" android:textStyle="bold" android:textColor="@color/accent" />
    <TextView android:id="@+id/tvTierPrice" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="@color/text_primary" android:layout_marginTop="4dp" />
    <TextView android:id="@+id/tvTierDuration" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginTop="2dp" />
</LinearLayout>
