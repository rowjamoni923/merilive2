            app:destination="@id/callHistoryFragment" />
        <action android:id="@+id/action_profile_to_faceVerification"
            app:destination="@id/faceVerificationFragment" />
        <action android:id="@+id/action_profile_to_tasks"
            app:destination="@id/tasksFragment" />
        <action android:id="@+id/action_profile_to_invitation"
            app:destination="@id/invitationFragment" />
        <action android:id="@+id/action_profile_to_rewards"
            app:destination="@id/rewardsFragment" />
        <action android:id="@+id/action_profile_to_hostApplication"
            app:destination="@id/hostApplicationFragment" />
        <action android:id="@+id/action_profile_to_withdrawal"
            app:destination="@id/withdrawalFragment" />
        <action android:id="@+id/action_profile_to_helperDashboard"
            app:destination="@id/helperDashboardFragment" />
