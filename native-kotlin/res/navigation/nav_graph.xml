        android:name="com.merilive.app.ui.call.PrivateCallFragment"
        android:label="Call">
        <argument android:name="calleeId" app:argType="string" />
        <argument android:name="callType" app:argType="string" android:defaultValue="video" />
    </fragment>

    <!-- Call History -->
    <fragment android:id="@+id/callHistoryFragment"
        android:name="com.merilive.app.ui.call.CallHistoryFragment"
