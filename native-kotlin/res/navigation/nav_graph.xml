        <argument android:name="streamId" app:argType="string" />
        <action android:id="@+id/action_live_to_privateCall"
            app:destination="@id/privateCallFragment" />
        <action android:id="@+id/action_live_to_userProfile"
            app:destination="@id/userProfileFragment" />
    </fragment>

    <!-- Party Room -->
    <fragment android:id="@+id/partyRoomFragment"
        android:name="com.merilive.app.ui.party.PartyRoomFragment"
        android:label="Party">
        <argument android:name="roomId" app:argType="string" />
        <action android:id="@+id/action_party_to_userProfile"
            app:destination="@id/userProfileFragment" />
    </fragment>

    <!-- Create Party -->
    <fragment android:id="@+id/createPartyFragment"
        android:name="com.merilive.app.ui.party.CreatePartyFragment"
        android:label="Create Party" />

    <!-- Private Call -->
