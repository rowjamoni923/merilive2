        <action android:id="@+id/action_explore_to_partyRoom"
            app:destination="@id/partyRoomFragment" />
        <action android:id="@+id/action_explore_to_liveStream"
            app:destination="@id/liveStreamFragment" />
        <action android:id="@+id/action_explore_to_userProfile"
            app:destination="@id/userProfileFragment" />
        <action android:id="@+id/action_explore_to_createParty"
            app:destination="@id/createPartyFragment" />
    </fragment>

    <!-- ========== TAB 3: GO LIVE (Host Only) ========== -->
    <fragment android:id="@+id/goLiveFragment"
        android:name="com.merilive.app.ui.live.GoLiveFragment"
        android:label="Go Live" />

    <!-- ========== TAB 4: CHAT ========== -->
    <fragment android:id="@+id/chatListFragment"
