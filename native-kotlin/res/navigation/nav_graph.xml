            app:destination="@id/levelFragment" />
        <action android:id="@+id/action_profile_to_vip"
            app:destination="@id/vipFragment" />
        <action android:id="@+id/action_profile_to_shop"
            app:destination="@id/shopFragment" />
        <action android:id="@+id/action_profile_to_agency"
            app:destination="@id/agencyFragment" />
        <action android:id="@+id/action_profile_to_hostDashboard"
            app:destination="@id/hostDashboardFragment" />
        <action android:id="@+id/action_profile_to_followers"
            app:destination="@id/followersFragment" />
        <action android:id="@+id/action_profile_to_following"
