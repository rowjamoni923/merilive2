<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================
     MeriLive - Complete Navigation Graph
     All screens with actions
     ============================================ -->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- ========== TAB 1: HOME ========== -->
    <fragment android:id="@+id/homeFragment"
        android:name="com.merilive.app.ui.home.HomeFragment"
        android:label="Home">
        <action android:id="@+id/action_home_to_liveStream"
            app:destination="@id/liveStreamFragment" />
        <action android:id="@+id/action_home_to_partyRoom"
            app:destination="@id/partyRoomFragment" />
        <action android:id="@+id/action_home_to_leaderboard"
            app:destination="@id/leaderboardFragment" />
        <action android:id="@+id/action_home_to_search"
            app:destination="@id/searchFragment" />
        <action android:id="@+id/action_home_to_notifications"
            app:destination="@id/notificationsFragment" />
        <action android:id="@+id/action_home_to_userProfile"
            app:destination="@id/userProfileFragment" />
        <action android:id="@+id/action_home_to_recharge"
            app:destination="@id/rechargeFragment" />
        <action android:id="@+id/action_home_to_vip"
            app:destination="@id/vipFragment" />
        <action android:id="@+id/action_home_to_shop"
            app:destination="@id/shopFragment" />
        <action android:id="@+id/action_home_to_tasks"
            app:destination="@id/tasksFragment" />
        <action android:id="@+id/action_home_to_goLive"
            app:destination="@id/goLiveFragment" />
    </fragment>

    <!-- ========== TAB 2: EXPLORE / PARTY ========== -->
    <fragment android:id="@+id/exploreFragment"
        android:name="com.merilive.app.ui.explore.ExploreFragment"
