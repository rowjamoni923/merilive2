# ============================================================
# LiveKit Media Stack — Environment
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- LiveKit SFU (already running on your VPS) ---
LIVEKIT_URL=wss://livekit.merilive.xyz
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Redis (shared between SFU + Egress + Ingress) ---
# Use a long random string. Example generator: openssl rand -hex 32
REDIS_PASSWORD=change_me_to_a_long_random_string

# --- S3 / Cloudflare R2 / MinIO (for Egress recordings) ---
# For Cloudflare R2:
#   ENDPOINT  = https://<account-id>.r2.cloudflarestorage.com
#   REGION    = auto
# For AWS S3:
#   ENDPOINT  = (leave empty)
#   REGION    = us-east-1 (or your region)
# For self-hosted MinIO:
#   ENDPOINT  = https://minio.merilive.xyz
#   REGION    = us-east-1
S3_BUCKET=merilive-recordings
S3_REGION=auto
S3_ACCESS_KEY=xxxxxxxxxxxxxxxx
S3_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Optional: public CDN base for recording playback URLs
# (e.g. R2 public bucket or Cloudflare custom domain)
# S3_PUBLIC_BASE=https://cdn.merilive.xyz
