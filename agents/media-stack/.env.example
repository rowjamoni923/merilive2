# ============================================================
# LiveKit Media Stack — VPS Environment
# Copy to .env on the VPS and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- LiveKit SFU (already running on your VPS) ---
LIVEKIT_URL=wss://livekit.merilive.xyz
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Redis (shared between SFU + Egress + Ingress) ---
# Generate: openssl rand -hex 32
REDIS_PASSWORD=change_me_to_a_long_random_string

# --- Cloudflare R2 (recordings storage) ---
# These are the SAME values you already have in Supabase secrets
# (R2_ACCOUNT_ID, R2_BUCKET_NAME, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY).
# Just copy them here so the VPS Egress container can upload directly.
S3_BUCKET=<your R2_BUCKET_NAME>
S3_REGION=auto
S3_ACCESS_KEY=<your R2_ACCESS_KEY_ID>
S3_SECRET=<your R2_SECRET_ACCESS_KEY>
S3_ENDPOINT=https://<your R2_ACCOUNT_ID>.r2.cloudflarestorage.com
