<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Pkg240 / M34 — Production: TLS-only for all known domains.
         Adds LiveKit self-hosted SFU, Cloudflare R2 egress, and Google Play
         endpoints used by Integrity / In-App Updates / Billing. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors><certificates src="system" /></trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="false">
        <!-- App + auth -->
        <domain includeSubdomains="true">merilive.com</domain>
        <domain includeSubdomains="true">merilive.xyz</domain>
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">supabase.com</domain>
        <domain includeSubdomains="true">lovable.app</domain>
        <domain includeSubdomains="true">lovableproject.com</domain>

        <!-- Payments -->
        <domain includeSubdomains="true">stripe.com</domain>

        <!-- Google services -->
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">firebase.google.com</domain>
        <domain includeSubdomains="true">firebaseio.com</domain>
        <domain includeSubdomains="true">google.com</domain>
        <domain includeSubdomains="true">gstatic.com</domain>

        <!-- Media -->
        <domain includeSubdomains="true">cloudinary.com</domain>

        <!-- Cloudflare R2 (egress / chat-media fallback) -->
        <domain includeSubdomains="true">r2.cloudflarestorage.com</domain>
        <domain includeSubdomains="true">r2.dev</domain>
        <domain includeSubdomains="true">cloudflare.com</domain>

        <trust-anchors><certificates src="system" /></trust-anchors>
    </domain-config>

    <!-- Debug-only: allow user-installed CAs (Charles / mitmproxy) for QA
         and reverse-engineering of upstream APIs. Release ignores this. -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
