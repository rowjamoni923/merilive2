<?xml version="1.0" encoding="utf-8"?>
<!--
  Pkg241 / M35 — Android 12+ Data Extraction Rules.
  Controls cloud auto-backup AND device-to-device transfer separately.
  Excludes sensitive prefs (auth tokens, biometric keys, FCM token, DM outbox,
  privacy consent, beauty filter cache). Includes safe user prefs (locale,
  theme, last-route hint, in-app update timestamps).
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude — sensitive / device-bound / regenerable -->
        <exclude domain="sharedpref" path="auth_prefs.xml" />
        <exclude domain="sharedpref" path="biometric_prefs.xml" />
        <exclude domain="sharedpref" path="fcm_prefs.xml" />
        <exclude domain="sharedpref" path="dm_outbox.xml" />
        <exclude domain="sharedpref" path="play_integrity.xml" />
        <exclude domain="sharedpref" path="call_state.xml" />
        <exclude domain="database" />
        <exclude domain="file" path="beauty_cache/" />
        <exclude domain="file" path="livekit_cache/" />
        <exclude domain="external" />
        <!-- WebView databases hold Supabase JWT — exclude entirely -->
        <exclude domain="file" path="app_webview/" />
        <exclude domain="file" path="app_webview_browserprocess/" />
    </cloud-backup>

    <device-transfer>
        <!-- D2D transfer (Android 12+ direct phone-to-phone) — same exclusions,
             plus we still strip auth so the new device must re-login. -->
        <exclude domain="sharedpref" path="auth_prefs.xml" />
        <exclude domain="sharedpref" path="biometric_prefs.xml" />
        <exclude domain="sharedpref" path="fcm_prefs.xml" />
        <exclude domain="sharedpref" path="play_integrity.xml" />
        <exclude domain="sharedpref" path="call_state.xml" />
        <exclude domain="database" />
        <exclude domain="file" path="beauty_cache/" />
        <exclude domain="file" path="livekit_cache/" />
        <exclude domain="file" path="app_webview/" />
        <exclude domain="file" path="app_webview_browserprocess/" />
    </device-transfer>
</data-extraction-rules>
