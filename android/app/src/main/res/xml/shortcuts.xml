<?xml version="1.0" encoding="utf-8"?>
<!--
  Pkg215 — Static App Shortcuts (launcher long-press menu).
  Each shortcut launches MainActivity with a "route" extra; MainActivity's
  handleNotificationRoute() forwards it to the WebView.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <shortcut
        android:shortcutId="go_live"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_live"
        android:shortcutShortLabel="@string/shortcut_live_short"
        android:shortcutLongLabel="@string/shortcut_live_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.merilive.app"
            android:targetClass="com.merilive.app.MainActivity">
            <extra android:name="route" android:value="/go-live" />
        </intent>
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <shortcut
        android:shortcutId="chat"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_chat"
        android:shortcutShortLabel="@string/shortcut_chat_short"
        android:shortcutLongLabel="@string/shortcut_chat_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.merilive.app"
            android:targetClass="com.merilive.app.MainActivity">
            <extra android:name="route" android:value="/chat" />
        </intent>
    </shortcut>

    <shortcut
        android:shortcutId="wallet"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_wallet"
        android:shortcutShortLabel="@string/shortcut_wallet_short"
        android:shortcutLongLabel="@string/shortcut_wallet_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.merilive.app"
            android:targetClass="com.merilive.app.MainActivity">
            <extra android:name="route" android:value="/recharge" />
        </intent>
    </shortcut>

    <shortcut
        android:shortcutId="discover"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_discover"
        android:shortcutShortLabel="@string/shortcut_discover_short"
        android:shortcutLongLabel="@string/shortcut_discover_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.merilive.app"
            android:targetClass="com.merilive.app.MainActivity">
            <extra android:name="route" android:value="/discover" />
        </intent>
    </shortcut>

</shortcuts>
