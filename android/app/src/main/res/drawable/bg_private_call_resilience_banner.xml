<?xml version="1.0" encoding="utf-8"?>
<!--
    Pkg500 Phase H — Resilience banner background.
    Used by CameraResilienceController to show "Camera unavailable — audio only"
    / "Phone overheating — camera paused" / "Poor connection" states.
    Dark red-orange tint to distinguish from low-balance (amber) banner.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E6D32F2F" />
    <corners android:radius="12dp" />
    <stroke android:width="1dp" android:color="#33FFFFFF" />
</shape>
