<?xml version="1.0" encoding="utf-8"?>
<!-- Pkg500 Phase D — low-balance warning banner background.
     Amber/red gradient with rounded corners; intensity comes from the
     parent layout's tint when warning escalates (60→30→10 → critical). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#E64A19"
        android:endColor="#BF360C"
        android:angle="45" />
    <corners android:radius="12dp" />
    <stroke android:width="1dp" android:color="#33FFFFFF" />
</shape>
