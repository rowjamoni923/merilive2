<?xml version="1.0" encoding="utf-8"?>
<!--
    Pkg500 Phase A — PrivateCallActivity layout (scaffold).

    Layer order (back → front):
      1. Black background (theme @android:color/black)
      2. privateCallRemoteVideo  — full-screen container; Phase B mounts the
         LiveKit remote VideoTextureView here.
      3. privateCallLocalPreview — 96x128dp PiP at top-right; Phase B mounts
         the local VideoTextureView here. Draggable behaviour is Phase C.
      4. privateCallLowBalanceSlot — Phase D inflates the warning banner here.
      5. Top overlay (peer avatar + name + state + duration + balance)
      6. Bottom action bar (mic / flip / beauty / gift / end)

    All ids prefixed `privateCall*` so a global search shows the surface.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fitsSystemWindows="false">

    <!-- Remote video surface (full-screen). Phase B mounts LiveKit
         VideoTextureView as the only child. -->
    <FrameLayout
        android:id="@+id/privateCallRemoteVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black" />

    <!-- Local preview PiP (top-right). Phase B mounts the local
         VideoTextureView. 96x128 keeps a 3:4 portrait crop without crowding
         the peer name. -->
    <FrameLayout
        android:id="@+id/privateCallLocalPreview"
        android:layout_width="96dp"
        android:layout_height="128dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_private_call_pip"
        android:elevation="6dp" />

    <!-- Top overlay (peer info + duration + balance). Scrim gradient keeps
         text readable over any background. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_private_call_top_scrim"
        android:paddingStart="16dp"
        android:paddingEnd="120dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/privateCallPeerAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_avatar_circle"
                android:scaleType="centerCrop"
                android:contentDescription="Peer avatar" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/privateCallPeerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calling…"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/privateCallState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Preparing…"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/privateCallDuration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:fontFamily="monospace"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/privateCallBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFD54F"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <!-- Low-balance banner slot (Phase D inflates here). -->
    <FrameLayout
        android:id="@+id/privateCallLowBalanceSlot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="140dp" />

    <!-- Bottom action bar. Five circular buttons inside a translucent scrim. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_private_call_bottom_scrim"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="36dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/privateCallBtnMic"
            style="@style/PrivateCallActionButton"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Mute microphone" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <ImageButton
            android:id="@+id/privateCallBtnFlip"
            style="@style/PrivateCallActionButton"
            android:src="@android:drawable/ic_menu_camera"
            android:contentDescription="Flip camera" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <ImageButton
            android:id="@+id/privateCallBtnBeauty"
            style="@style/PrivateCallActionButton"
            android:src="@android:drawable/ic_menu_view"
            android:contentDescription="Beauty filter" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <ImageButton
            android:id="@+id/privateCallBtnGift"
            style="@style/PrivateCallActionButton"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Send gift" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <ImageButton
            android:id="@+id/privateCallBtnEnd"
            style="@style/PrivateCallEndButton"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="End call" />
    </LinearLayout>
</FrameLayout>
